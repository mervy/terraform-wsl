# ── Senhas de bancos de dados ──────────────────────────────────────────────
# Copie este arquivo para .env e defina suas senhas ANTES de rodar qualquer
# script de banco de dados:
#
#   cp .env.example .env
#   nano .env
#
# REGRAS:
#   • O .env NUNCA é versionado (já está no .gitignore)
#   • Nunca coloque senhas diretamente nos scripts — use sempre este arquivo
#   • Evite usar aspas simples (') nas senhas (reservado para SQL literal)

# MongoDB (usuário: admin)
MONGODB_ADMIN_PASS=DEFINA_SUA_SENHA

# MySQL / MariaDB (usuários: root e admin)
MYSQL_ADMIN_PASS=DEFINA_SUA_SENHA

# PostgreSQL (usuários: postgres e admin)
POSTGRES_ADMIN_PASS=DEFINA_SUA_SENHA

# Senha de sistema para root e usuário (usado pelo gentoo-init.sh)
SYSTEM_USER_PASS=DEFINA_SUA_SENHA
